{
	"name": "sensahin/pufferdesk",
	"description": "Turn your WordPress admin into a desktop workspace.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"squizlabs/php_codesniffer": "^3.13",
		"wp-coding-standards/wpcs": "^3.3"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"lint:php": "phpcs --standard=.phpcs.xml.dist",
		"lint:php:fix": "phpcbf --standard=.phpcs.xml.dist",
		"lint:php:syntax": "find . -path './node_modules' -prune -o -path './release' -prune -o -path './vendor' -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l"
	}
}
